# Sentinel Environment Variables
# Copy this to .env and fill in your values

# === REQUIRED ===
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# === OPTIONAL: Azure Cosmos DB (for persistent audit log) ===
COSMOS_ENDPOINT=your_cosmos_endpoint
COSMOS_KEY=your_cosmos_key
COSMOS_DB_NAME=sentinel
COSMOS_CONTAINER=audit_log

# === OPTIONAL: Flask ===
FLASK_SECRET_KEY=change_this_to_a_random_string
FLASK_ENV=development
FLASK_PORT=5000

# === SCAN DEFAULTS ===
# Comma-separated list of approved target hostnames/IPs (local dev)
APPROVED_TARGETS=localhost,127.0.0.1,dvwa.local,juice-shop.local

# Max findings before orchestrator stops a scan (safety limit)
MAX_FINDINGS=500

# Model to use for orchestrator
ORCHESTRATOR_MODEL=claude-sonnet-4-20250514

# Model for sub-agents (cheaper)
AGENT_MODEL=claude-haiku-4-5-20251001
