# ── REQUIRED ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── OPTIONAL: Multi-model consensus (GPT-4o cross-reference) ──────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── OPTIONAL: Azure Cosmos DB (persistent audit log) ──────────────────────────
COSMOS_ENDPOINT=your_cosmos_endpoint
COSMOS_KEY=your_cosmos_key
COSMOS_DB_NAME=sentinel
COSMOS_CONTAINER=audit_log

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_SECRET_KEY=change_this_to_a_random_string
FLASK_ENV=development
FLASK_PORT=5000

# ── Scan settings ─────────────────────────────────────────────────────────────
# Comma-separated approved targets for local dev
APPROVED_TARGETS=localhost,127.0.0.1,dvwa.local,juice-shop.local,http://localhost:3000

# Claude model to use for orchestrator (most capable)
ORCHESTRATOR_MODEL=claude-sonnet-4-20250514

# Claude model for sub-agents (faster/cheaper)
AGENT_MODEL=claude-haiku-4-5-20251001

# Max findings per scan before stopping
MAX_FINDINGS=1000
